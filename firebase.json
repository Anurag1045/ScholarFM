{
  "hosting": {
    "public": "frontend",
    "ignore": ["firebase.json", "**/.*"],
    "rewrites": [
      { "source": "/login", "destination": "/login.html" },
      { "source": "/app", "destination": "/app.html" }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
